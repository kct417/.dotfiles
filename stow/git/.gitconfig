[user]
	email = caseytran4@gmail.com
	name = Casey Tran

[init]
	defaultBranch = main

[fetch]
	parallel = 0

[submodule]
	fetchJobs = 0

[diff]
	renames = copies
	colorMoved = default

[alias]
	a = add
	ad = add .
	aa = add -A
	au = add -u

	c = commit
	cm = commit -m
	ac = commit -am
	ca = commit --amend -m

	cl = clone
	clr = clone --recursive

	l = log --pretty=oneline -n 20 --graph --abbrev-commit

	ps = push
	pl = pull --recurse-submodules

	r = reset
	rhd = reset HEAD
	rh = reset --hard
	rs = reset --soft

	s = status
	d = diff
	ds = diff --staged

	subadd = submodule add
	subup = submodule update --init --recursive
	subsync = submodule sync --recursive
